{
  "kind": "collectionType",
  "collectionName": "formcraft_forms",
  "info": {
    "singularName": "form",
    "pluralName": "forms",
    "displayName": "Form",
    "description": "Dynamic form definitions"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": { "visible": false },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "title": { "type": "string", "required": true, "maxLength": 255 },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "description": { "type": "text" },
    "fields": { "type": "json", "required": true, "default": [] },
    "conditionalLogic": { "type": "json", "default": [] },
    "publishedData": { "type": "json" },
    "settings": {
      "type": "json",
      "default": {
        "submitButtonText": "Submit",
        "successMessage": "Form submitted successfully",
        "enableHoneypot": true,
        "enableRateLimit": true,
        "maxSubmissionsPerHour": 60,
        "notificationEmails": [],
        "redirectUrl": "",
        "customCss": "",
        "captcha": { "provider": "none", "siteKey": "", "secretKey": "" }
      }
    },
    "submissions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::strapi-plugin-form-builder-cms.form-submission",
      "mappedBy": "form"
    }
  }
}
